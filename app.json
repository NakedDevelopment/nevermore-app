{
  "expo": {
    "name": "nevermore-app",
    "slug": "nevermore-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./src/assets/App_Icon.png",
    "splash": {
      "image": "./src/assets/splash-bg.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "nevermoreapp",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nevermore.app",
      "buildNumber": "92",
      "splash": {
        "image": "./src/assets/splash-bg.png",
        "resizeMode": "cover",
        "backgroundColor": "#000000"
      },
      "associatedDomains": [
        "applinks:nevermoreapp.com"
      ],
      "appleTeamId": "C5DF3CP9LJ",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/App_Icon.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./src/assets/splash-bg.png",
        "resizeMode": "cover",
        "backgroundColor": "#000000"
      },
      "package": "com.nevermoreapp",
      "versionCode": 5,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nevermoreapp.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "nevermoreapp.com",
              "pathPrefix": "/create-new-password"
            },
            {
              "scheme": "https",
              "host": "nevermoreapp.com",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./src/assets/App_Icon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/App_Icon.png",
          "backgroundColor": "#2D1B69"
        }
      ],
      "expo-audio",
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "2158a613-0b10-4a89-8601-c6ac4e2389a9"
      }
    }
  }
}
